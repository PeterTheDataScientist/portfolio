---
import { competitions, zindiProfile } from '../data/competitions';

// Marker position: better rank sits closer to the left edge.
const positionOf = (rank: number, total: number) =>
  total > 1 ? ((rank - 1) / (total - 1)) * 100 : 0;
---

<ul class="rank-list">
  {competitions.map((c) => {
    const pos = positionOf(c.rank, c.total);
    return (
      <li class="rank-row">
        <div class="rank-row__head">
          <span class="rank-row__place">{c.place}</span>
          <span class="rank-row__of">of {c.total}</span>
          <span class="rank-row__title">
            {c.title}
            {c.repo && (
              <a class="comp-item__repo" href={c.repo} target="_blank" rel="noopener">code</a>
            )}
          </span>
        </div>
        <div class="rank-track" role="img" aria-label={`Placed ${c.place} of ${c.total}`}>
          <span class="rank-track__fill" style={`width: ${pos}%`}></span>
          <span class="rank-track__marker" style={`left: ${pos}%`}></span>
        </div>
      </li>
    );
  })}
</ul>
<p class="comp-profile">
  <a href={zindiProfile} target="_blank" rel="noopener">Full Zindi profile (PeterTheAnalyst) &rarr;</a>
</p>
