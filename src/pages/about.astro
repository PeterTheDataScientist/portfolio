---
import BaseLayout from '../layouts/BaseLayout.astro';
import Certifications from '../components/Certifications.astro';
import Competitions from '../components/Competitions.astro';
import Moments from '../components/Moments.astro';
import { externalWriting } from '../data/external-writing';

const recentWriting = externalWriting.slice(0, 4);

// Only render the "In the room" band when at least one photo exists.
const hasMoments = Object.keys(
  import.meta.glob('/src/assets/moments/*.{jpg,jpeg,png,webp}')
).length > 0;

const ituArticle = 'https://www.itu.int/hub/2026/06/ai-for-good-meet-the-people-powering-machine-learning-solutions/';

const skillGroups = [
  { tier: 'Core', note: 'daily tools', items: ['Python', 'SQL / T-SQL', 'PostgreSQL', 'Power BI', 'PyTorch', 'React'] },
  { tier: 'Production', note: 'build and ship with', items: ['Express', 'TypeScript', 'Drizzle ORM', 'MindStudio', 'Streamlit'] },
  { tier: 'Frameworks & libraries', note: '', items: ['TensorFlow', 'scikit-learn', 'LightGBM', 'XGBoost', 'YOLOv8', 'OpenCV'] },
  { tier: 'Platforms & infrastructure', note: '', items: ['SAP Business One', 'PostgreSQL-based ERP', 'Azure', 'AWS', 'GitHub'] },
];

const timeline = [
  { year: '2026', title: 'Data Scientist, AI Creative Solutions', detail: 'Current role: machine learning, analytics, and governed AI systems on production data.' },
  { year: '2026', title: 'BSc Data Science graduation', detail: 'Completed BSc Data Science and Informatics with Upper Second Class Honours (2.1); graduation ceremony August 2026.' },
  { year: '2026', title: 'Best Poster, IndabaX Zimbabwe', detail: 'For ZimCropGuard, my ongoing multi-crop disease research, with selection to represent Zimbabwe at the Deep Learning Indaba 2027.' },
  { year: '2026', title: 'Featured in ITU News', detail: '"AI for Good: Meet the people powering machine-learning solutions."' },
  { year: '2025-26', title: 'President, R:Ed Zimbabwe Chapter', detail: 'Led the Right for Education Zimbabwe Chapter (Oct 2025 to May 2026): strategy, editorial standards, and cross-chapter coordination.' },
  { year: '2025', title: 'Zindi Ambassador for Zimbabwe', detail: 'Appointed August 2025: organising events, running competitions, and mentoring practitioners.' },
  { year: '2024-25', title: 'Vice President, R:Ed Zimbabwe Chapter', detail: 'Led the writing team and publishing workflow (Aug 2024 to Oct 2025).' },
  { year: '2024-25', title: 'Revenue Assurance Intern, Steward Bank', detail: 'Revenue-assurance dashboards and automated data extraction across billing systems.' },
  { year: '2022', title: 'Started BSc Data Science', detail: 'University of Zimbabwe.' },
];
---

<BaseLayout
  title="About"
  description="Peter Tinashe Mundowa is a Data Scientist at AI Creative Solutions, building machine learning, analytics, and governed AI systems for African enterprises."
>
  <section class="band band--hero band--hero-flush">
    <div class="container">
      <p class="hero__eyebrow">About</p>
      <div class="about-hero">
        <img
          class="about-photo"
          src="/photo.jpg"
          alt="Peter Tinashe Mundowa"
          width="200"
          height="200"
          loading="eager"
        />
        <div class="hero-stats">
          <div class="hero-stat" data-reveal>
            <div class="hero-stat__value">3×</div>
            <div class="hero-stat__label">Microsoft certifications</div>
          </div>
          <div class="hero-stat" data-reveal>
            <div class="hero-stat__value">12+</div>
            <div class="hero-stat__label">Zindi competitions</div>
          </div>
          <div class="hero-stat" data-reveal>
            <div class="hero-stat__value">10+</div>
            <div class="hero-stat__label">Published articles</div>
          </div>
          <div class="hero-stat" data-reveal>
            <div class="hero-stat__value">Aug 2026</div>
            <div class="hero-stat__label">BSc (2.1) graduation</div>
          </div>
        </div>
      </div>
      <h1 class="hero__title">A Data Scientist who ships what he <em>models.</em></h1>
    </div>
  </section>

  <section class="band band--tight">
    <div class="container">
      <div class="case-study__content">
        <p>I started out at a bank, building revenue-assurance dashboards and automating data pipelines across billing systems. That year taught me something I have never let go of: getting a model to work is the easy part, and the real distance is between a model that works in a notebook and a system that delivers a correct answer, every day, to someone who is about to make a decision with it.</p>

        <p>Today I am a Data Scientist at AI Creative Solutions, where I take the messy, undocumented data organisations actually run on and turn it into models, analytics, and decision systems they can trust. In practice that means feature engineering on data that fights back, analytics pipelines reconciled against a human source of truth, and governed AI agents that are kept nowhere near a number they could invent. I build the production platforms around that work too, because a model only matters once it reaches the people making decisions.</p>

        <p>I have a strong opinion about applied AI: the model is the easy part. You can swap it on a Tuesday and nobody notices. The value lives in everything around it, the data wrangling, the feature work, the evidence governance, and the analytics that make a result trustworthy enough to act on. That is the part I build, and it is the part most demos quietly skip.</p>

        <p>Beyond client work, I research applied machine learning for African field conditions, compete and organise as Zimbabwe's Zindi Ambassador, and write for audiences across the continent. I care about the same thing in all of it: building things that hold up when they meet the messy reality they were made for.</p>

        <h2>Technical range</h2>
        <p>Python, PyTorch, TensorFlow, scikit-learn, YOLOv8, T-SQL, PostgreSQL, Power BI, MindStudio, React, TypeScript, Express, Drizzle ORM, SAP Business One (SQL Server), a PostgreSQL-based ERP, and Azure cloud services. I work across the full data science lifecycle, from data wrangling and modelling through analytics to production AI systems.</p>

        <h2>Education</h2>
        <p>BSc in Data Science and Informatics (Upper Second Class Honours, 2.1), University of Zimbabwe. Graduating August 2026.</p>
      </div>
    </div>
  </section>

  <section class="band band--alt">
    <div class="container">
      <p class="section__label"><span class="section__num">01</span> Technical proficiency</p>
      <h2 class="section__title">Where my hours go.</h2>
      <div class="skill-groups">
        {skillGroups.map((g) => (
          <div class="skill-group" data-reveal>
            <h3 class="skill-group__title">
              {g.tier}
              {g.note && <span class="skill-group__note">{g.note}</span>}
            </h3>
            <div class="skill-group__tags">
              {g.items.map((item) => <span class="tech-tag tech-tag--lg">{item}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="band">
    <div class="container">
      <p class="section__label"><span class="section__num">02</span> Career timeline</p>
      <h2 class="section__title">The path so far.</h2>
      <ul class="timeline">
        {timeline.map((t) => (
          <li class="timeline__item" data-reveal>
            <span class="timeline__year">{t.year}</span>
            <div class="timeline__body">
              <span class="timeline__title">{t.title}</span>
              <span class="timeline__detail">{t.detail}</span>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="band band--alt">
    <div class="container">
      <p class="section__label"><span class="section__num">03</span> Recognition & features</p>
      <h2 class="section__title">Work that travelled.</h2>
      <div class="case-study__content">
        <ul>
          <li>Featured in <strong>ITU News</strong> (June 2026), <a href={ituArticle} target="_blank" rel="noopener">"AI for Good: Meet the people powering machine-learning solutions"</a>.</li>
          <li><strong>Best Poster</strong> at IndabaX Zimbabwe 2026 for ZimCropGuard, my ongoing multi-crop disease detection research (EfficientNet and a Vision Transformer, fused). It builds on my completed BSc dissertation, a hybrid CNN-Transformer for tomato leaf disease.</li>
          <li><strong>Selected for the Deep Learning Indaba 2027</strong>, representing Zimbabwe.</li>
          <li><strong>3rd place</strong> at the ITU AI/ML Global Challenge.</li>
          <li><strong>Speaker</strong> at IndabaX Zimbabwe 2025 (demo and startup session).</li>
        </ul>
        <blockquote style="border-left: 3px solid var(--color-accent); padding-left: 1rem; margin: 1.5rem 0; color: var(--color-text-secondary); font-style: italic;">
          "Do not wait until you feel fully ready to participate." <span style="font-style: normal; color: var(--color-text-tertiary);">My advice in ITU News.</span>
        </blockquote>
      </div>
    </div>
  </section>

  {hasMoments && (
    <section class="band">
      <div class="container">
        <p class="section__label"><span class="section__num">04</span> Beyond the desk</p>
        <h2 class="section__title">In the room.</h2>
        <Moments />
      </div>
    </section>
  )}

  <section class={hasMoments ? 'band band--alt' : 'band'}>
    <div class="container">
      <p class="section__label"><span class="section__num">{hasMoments ? '05' : '04'}</span> Competitions</p>
      <h2 class="section__title">Measured against the field.</h2>
      <Competitions />
    </div>
  </section>

  <section class={hasMoments ? 'band' : 'band band--alt'}>
    <div class="container">
      <p class="section__label"><span class="section__num">{hasMoments ? '06' : '05'}</span> Certifications</p>
      <h2 class="section__title">Verified, not just claimed.</h2>
      <Certifications />
    </div>
  </section>

  <section class={hasMoments ? 'band band--alt' : 'band'}>
    <div class="container">
      <p class="section__label"><span class="section__num">{hasMoments ? '07' : '06'}</span> Community & leadership</p>
      <h2 class="section__title">Building the ecosystem.</h2>
      <ul class="lead-list">
        <li data-reveal><strong>Zindi Ambassador for Zimbabwe</strong> (2025 to present): organising events, running competitions, and mentoring practitioners.</li>
        <li data-reveal><strong>Right for Education Zimbabwe</strong>: Author (Feb 2024 to present), former Chapter President (Oct 2025 to May 2026), and former Vice President (Aug 2024 to Oct 2025).</li>
        <li data-reveal>Organised a career development event that drew <strong>100+ attendees</strong> and ran 90 minutes, extended for an engaged Q&amp;A.</li>
        <li data-reveal>Recipient of the <strong>R:Ed Leadership Beacon Award</strong>.</li>
        <li data-reveal>Awarded the <strong>R:Ed Certificate of Excellence in Leadership Support</strong>.</li>
      </ul>
    </div>
  </section>

  <section class={hasMoments ? 'band' : 'band band--alt'}>
    <div class="container">
      <p class="section__label"><span class="section__num">{hasMoments ? '08' : '07'}</span> Published writing</p>
      <h2 class="section__title">Writing for Africa.</h2>
      <div class="case-study__content">
        <p>I write about technology, leadership, and Africa for Right for Education, reaching audiences across the continent. A few recent pieces:</p>
        <ul class="about-writing">
          {recentWriting.map((article) => (
            <li>
              <a href={article.url} target="_blank" rel="noopener">{article.title}</a>
            </li>
          ))}
        </ul>
        <p><a href="/blog">See all writing &rarr;</a></p>
      </div>
    </div>
  </section>
</BaseLayout>
