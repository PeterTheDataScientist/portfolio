---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Data Scientist & AI Engineer"
  description="Peter Tinashe Mundowa — Data Scientist & AI Engineer building intelligent systems for African enterprises. Based in Harare, Zimbabwe."
>
  <div class="container">
    <section class="hero">
      <p class="hero__eyebrow">Data Scientist & AI Engineer — Harare, Zimbabwe</p>
      <h1 class="hero__title">I build intelligent systems on enterprise data <em>nobody documented.</em></h1>
      <p class="hero__subtitle">
        From undocumented ERP schemas to production AI agents — I design systems that make enterprises smarter, on real data, with real stakes.
        Currently at AI Creative Solutions.
      </p>
      <div class="hero__meta">
        <span class="hero__meta-item">3× Microsoft Certified</span>
        <span class="hero__meta-item">Zindi Ambassador, Zimbabwe</span>
        <span class="hero__meta-item">Featured in ITU News</span>
        <span class="hero__meta-item">IndabaX Best Poster 2026</span>
      </div>
    </section>

    <section class="section" id="work">
      <p class="section__label">Selected work</p>
      <h2 class="section__title">Built for real problems.</h2>
      <div class="work-grid">

        <a href="/work/operations-command-centre" class="work-card">
          <span class="work-card__sector">Manufacturing</span>
          <h3 class="work-card__title">Enterprise operations command centre</h3>
          <p class="work-card__desc">
            Replaced a legacy CRM and built a live operations platform with AI-governed query execution across 80+ branches.
          </p>
          <div class="work-card__stats">
            <span class="work-card__stat"><strong>75+</strong> tables</span>
            <span class="work-card__stat"><strong>44+</strong> AI action tools</span>
            <span class="work-card__stat"><strong>~$100K/yr</strong> CRM replaced</span>
          </div>
          <div class="tech-tags">
            <span class="tech-tag">React</span>
            <span class="tech-tag">TypeScript</span>
            <span class="tech-tag">PostgreSQL</span>
            <span class="tech-tag">MindStudio</span>
            <span class="tech-tag">Openbravo</span>
          </div>
        </a>

        <a href="/work/agricultural-trading-platform" class="work-card">
          <span class="work-card__sector">Agriculture / Finance</span>
          <h3 class="work-card__title">Agricultural trading platform</h3>
          <p class="work-card__desc">
            Replaced a 12-year undocumented Access database for a multi-million-dollar trading operation. Bank-grade security retrofit from zero.
          </p>
          <div class="work-card__stats">
            <span class="work-card__stat"><strong>60+</strong> tables migrated</span>
            <span class="work-card__stat"><strong>24,600+</strong> transactions</span>
            <span class="work-card__stat"><strong>866</strong> tests</span>
          </div>
          <div class="tech-tags">
            <span class="tech-tag">React</span>
            <span class="tech-tag">Express</span>
            <span class="tech-tag">PostgreSQL</span>
            <span class="tech-tag">Drizzle ORM</span>
          </div>
        </a>

        <a href="/work/dairy-production-intelligence" class="work-card">
          <span class="work-card__sector">Dairy Manufacturing</span>
          <h3 class="work-card__title">Dairy production intelligence suite</h3>
          <p class="work-card__desc">
            Three integrated systems — a production tracker, a hallucination-proof planning agent, and a real-time debtors dashboard — all connected to a live SAP ERP.
          </p>
          <div class="work-card__stats">
            <span class="work-card__stat"><strong>93</strong> products tracked</span>
            <span class="work-card__stat"><strong>2,125</strong> debtor accounts</span>
            <span class="work-card__stat"><strong>33</strong> agent blocks</span>
          </div>
          <div class="tech-tags">
            <span class="tech-tag">React</span>
            <span class="tech-tag">SAP B1</span>
            <span class="tech-tag">MindStudio</span>
            <span class="tech-tag">Python</span>
            <span class="tech-tag">T-SQL</span>
          </div>
        </a>

        <a href="/work/crop-disease-detection" class="work-card">
          <span class="work-card__sector">Agriculture / Computer Vision</span>
          <h3 class="work-card__title">Hybrid CNN-Transformer for crop disease detection</h3>
          <p class="work-card__desc">
            BSc research: a robustness-engineered model that closes the lab-to-field accuracy gap for smallholder farmers using budget phones.
          </p>
          <div class="work-card__stats">
            <span class="work-card__stat"><strong>+36pt</strong> low-light F1 gain</span>
            <span class="work-card__stat"><strong>14.88M</strong> parameters</span>
            <span class="work-card__stat"><strong>Best Poster</strong> IndabaX 2026</span>
          </div>
          <div class="tech-tags">
            <span class="tech-tag">PyTorch</span>
            <span class="tech-tag">ResNet18</span>
            <span class="tech-tag">Transformer</span>
            <span class="tech-tag">Streamlit</span>
          </div>
        </a>
      </div>
    </section>

    <section class="section">
      <p class="section__label">Credentials</p>
      <h2 class="section__title">Not just theory.</h2>
      <div class="cred-grid">
        <div class="cred-item">
          <p class="cred-item__label">Microsoft Azure</p>
          <p class="cred-item__value">AI Engineer Associate</p>
        </div>
        <div class="cred-item">
          <p class="cred-item__label">Microsoft Azure</p>
          <p class="cred-item__value">Data Scientist Associate</p>
        </div>
        <div class="cred-item">
          <p class="cred-item__label">Microsoft Power BI</p>
          <p class="cred-item__value">Data Analyst Associate</p>
        </div>
        <div class="cred-item">
          <p class="cred-item__label">University of Zimbabwe</p>
          <p class="cred-item__value">BSc Data Science (Aug 2026)</p>
        </div>
        <div class="cred-item">
          <p class="cred-item__label">Competition</p>
          <p class="cred-item__value">3rd — ITU AI/ML Global</p>
        </div>
        <div class="cred-item">
          <p class="cred-item__label">Recognition</p>
          <p class="cred-item__value">Featured in ITU News</p>
        </div>
        <div class="cred-item">
          <p class="cred-item__label">Community</p>
          <p class="cred-item__value">Zindi Ambassador, Zimbabwe</p>
        </div>
        <div class="cred-item">
          <p class="cred-item__label">Conference</p>
          <p class="cred-item__value">Deep Learning Indaba 2027</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
