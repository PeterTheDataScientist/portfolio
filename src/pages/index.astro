---
import BaseLayout from '../layouts/BaseLayout.astro';
import Certifications from '../components/Certifications.astro';
import Competitions from '../components/Competitions.astro';

const metrics = [
  { value: '225,000+', count: 225000, decimals: 0, prefix: '', suffix: '+', label: 'Transactions analysed' },
  { value: '95.56%', count: 95.56, decimals: 2, prefix: '', suffix: '%', label: 'Schema join accuracy' },
  { value: '+36pt', count: 36, decimals: 0, prefix: '+', suffix: 'pt', label: 'Low-light F1 improvement' },
  { value: '5 min', count: null, decimals: 0, prefix: '', suffix: '', label: 'Insight turnaround (from days)' },
];
---

<BaseLayout
  title="Data Scientist & AI Engineer"
  description="Peter Tinashe Mundowa is a Data Scientist and AI Engineer turning messy enterprise data into models, analytics, and governed AI agents. Based in Harare, Zimbabwe."
>
  <section class="band band--hero">
    <div class="container">
      <div class="hero__accent"></div>
      <div class="hero__header">
        <img
          class="hero__photo"
          src="/photo.jpg"
          alt="Peter Tinashe Mundowa"
          width="160"
          height="160"
          loading="eager"
        />
        <div>
          <p class="hero__eyebrow">Data Scientist & AI Engineer · Harare, Zimbabwe</p>
          <h1 class="hero__title">I turn undocumented enterprise data into <em>models you can trust.</em></h1>
        </div>
      </div>
      <p class="hero__subtitle">
        I am a Data Scientist and AI Engineer, currently at AI Creative Solutions. My work spans machine learning, analytics, and the governed AI agents and platforms that put data science into production, on real data, with real stakes.
      </p>
      <div class="hero__actions">
        <a class="btn-download" href="/cv.pdf" download>↓ Download CV</a>
        <a class="btn-download" href="#work">View my work</a>
      </div>
      <div class="hero__meta">
        <span class="hero__meta-item">3× Microsoft Certified</span>
        <span class="hero__meta-item">Zindi Ambassador, Zimbabwe</span>
        <span class="hero__meta-item">Featured in ITU News</span>
        <span class="hero__meta-item">IndabaX Best Poster 2026</span>
      </div>
      <div class="now-bar">
        <span class="now-bar__tag"><span class="now-bar__dot"></span>Now</span>
        <span>Data Scientist at AI Creative Solutions, building ML systems, analytics pipelines, and governed AI agents. Open to remote collaboration, research, and speaking.</span>
      </div>
    </div>
  </section>

  <section class="band band--feature" aria-label="Recognition">
    <div class="container">
      <div class="recognition-bar">
        <span class="recognition-bar__label">As featured in</span>
        <div class="recognition-bar__items">
          <span class="recognition-bar__item"><a href="https://www.itu.int/hub/2026/06/ai-for-good-meet-the-people-powering-machine-learning-solutions/" target="_blank" rel="noopener">ITU News</a></span>
          <span class="recognition-bar__item">IndabaX Zimbabwe</span>
          <span class="recognition-bar__item">Deep Learning Indaba</span>
          <span class="recognition-bar__item"><a href="https://zindi.africa/users/PeterTheAnalyst" target="_blank" rel="noopener">Zindi</a></span>
        </div>
      </div>
    </div>
  </section>

  <section class="band" id="work">
    <div class="container">
      <p class="section__label"><span class="section__num">01</span> Selected work</p>
      <h2 class="section__title">Data science, put into production.</h2>
      <div class="work-grid">

        <a href="/work/zimcropguard" class="work-card" data-reveal>
          <span class="work-card__sector">Computer vision research</span>
          <h3 class="work-card__title">ZimCropGuard: multi-crop disease detection</h3>
          <p class="work-card__desc">
            Ongoing research scaling my dissertation to 5 crops and 21+ diseases across real African field conditions, with an explicit domain-shift study.
          </p>
          <div class="work-card__stats">
            <span class="work-card__stat"><strong>Best Poster</strong> IndabaX 2026</span>
            <span class="work-card__stat"><strong>5 crops</strong> 21+ classes</span>
            <span class="work-card__stat"><strong>54K+</strong> training images</span>
          </div>
          <div class="tech-tags">
            <span class="tech-tag">PyTorch</span>
            <span class="tech-tag">EfficientNetB0</span>
            <span class="tech-tag">ViT-B/16</span>
            <span class="tech-tag">Streamlit</span>
          </div>
        </a>

        <a href="/work/applied-ml-research" class="work-card" data-reveal>
          <span class="work-card__sector">Machine learning research</span>
          <h3 class="work-card__title">Hybrid CNN-Transformer for tomato leaf disease</h3>
          <p class="work-card__desc">
            My completed BSc dissertation, deployed as a live Streamlit app: a robustness-engineered model that closes the lab-to-field gap on budget phones. The proof of concept beneath ZimCropGuard.
          </p>
          <div class="work-card__stats">
            <span class="work-card__stat"><strong>+36pt</strong> low-light F1 gain</span>
            <span class="work-card__stat"><strong>Live</strong> Streamlit demo</span>
            <span class="work-card__stat"><strong>Deployed</strong> BSc dissertation</span>
          </div>
          <div class="tech-tags">
            <span class="tech-tag">PyTorch</span>
            <span class="tech-tag">ResNet18</span>
            <span class="tech-tag">Transformer</span>
            <span class="tech-tag">Streamlit</span>
          </div>
        </a>

        <a href="/work/ai-agent-orchestration" class="work-card" data-reveal>
          <span class="work-card__sector">AI engineering</span>
          <h3 class="work-card__title">AI agent orchestration</h3>
          <p class="work-card__desc">
            AI agents that query live enterprise databases in real time. The model never does the arithmetic; every figure is computed by deterministic code from query results, so fabricated numbers cannot occur.
          </p>
          <div class="tech-tags">
            <span class="tech-tag">MindStudio</span>
            <span class="tech-tag">PostgreSQL</span>
            <span class="tech-tag">Python</span>
            <span class="tech-tag">TypeScript</span>
          </div>
        </a>

        <a href="/work/live-erp-integration" class="work-card" data-reveal>
          <span class="work-card__sector">Enterprise integration</span>
          <h3 class="work-card__title">Live ERP integration & analytics</h3>
          <p class="work-card__desc">
            Connecting to production SAP Business One and PostgreSQL-based ERP environments, reverse-engineering undocumented schemas into trustworthy analytics.
          </p>
          <div class="tech-tags">
            <span class="tech-tag">SAP Business One</span>
            <span class="tech-tag">PostgreSQL-based ERP</span>
            <span class="tech-tag">PostgreSQL</span>
            <span class="tech-tag">T-SQL</span>
          </div>
        </a>

        <a href="/work/legacy-system-modernisation" class="work-card" data-reveal>
          <span class="work-card__sector">Legacy modernisation</span>
          <h3 class="work-card__title">Legacy system modernisation</h3>
          <p class="work-card__desc">
            Replacing fragile legacy databases, spreadsheets, and manual accounting with secure, modern web platforms that become a single source of record.
          </p>
          <div class="tech-tags">
            <span class="tech-tag">React</span>
            <span class="tech-tag">TypeScript</span>
            <span class="tech-tag">PostgreSQL</span>
            <span class="tech-tag">Drizzle ORM</span>
          </div>
        </a>
      </div>
      <p class="view-all"><a href="/work">View all work &rarr;</a></p>
    </div>
  </section>

  <section class="band band--alt">
    <div class="container">
      <p class="section__label">By the numbers</p>
      <h2 class="section__title">Impact, measured.</h2>
      <div class="metric-grid">
        {metrics.map((m) => (
          <div class="metric" data-reveal>
            <div
              class="metric__value"
              data-count={m.count ?? undefined}
              data-decimals={m.decimals}
              data-prefix={m.prefix}
              data-suffix={m.suffix}
            >{m.value}</div>
            <div class="metric__label">{m.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="band">
    <div class="container">
      <p class="section__label"><span class="section__num">02</span> Data science & ML</p>
      <h2 class="section__title">Measured against the field.</h2>
      <p class="hero__subtitle" style="margin-bottom: 1.5rem;">
        I compete on Zindi as Zimbabwe's Ambassador, across computer vision, fraud detection, and tabular ML.
      </p>
      <Competitions />
    </div>
  </section>

  <section class="band band--alt">
    <div class="container">
      <p class="section__label"><span class="section__num">03</span> Certifications</p>
      <h2 class="section__title">Verified, not just claimed.</h2>
      <Certifications />
    </div>
  </section>
</BaseLayout>
