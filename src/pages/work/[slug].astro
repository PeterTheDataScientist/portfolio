---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const work = await getCollection('work');
  return work.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const articleURL = new URL(`/work/${entry.id}`, Astro.site).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.description,
  "url": articleURL,
  "mainEntityOfPage": articleURL,
  "about": entry.data.sector,
  "author": {
    "@type": "Person",
    "name": "Peter Tinashe Mundowa",
    "url": Astro.site?.toString(),
  },
};
---

<BaseLayout title={entry.data.title} description={entry.data.description} ogType="article" structuredData={structuredData}>
  <div class="container">
    <section class="case-study__header">
      <a href="/work" class="case-study__back">&larr; All work</a>
      <span class="work-card__sector">{entry.data.sector}</span>
      <h1 style="margin-top: 0.75rem;">{entry.data.title}</h1>
    </section>
    <section class="case-study__content">
      <Content />
    </section>
  </div>
</BaseLayout>
