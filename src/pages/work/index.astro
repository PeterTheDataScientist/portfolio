---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const work = await getCollection('work');
---

<BaseLayout title="Work" description="Selected case studies — enterprise AI, production platforms, and applied machine learning.">
  <div class="container">
    <section class="hero">
      <p class="hero__eyebrow">Work</p>
      <h1 class="hero__title">Built for <em>real problems.</em></h1>
      <p class="hero__subtitle">Enterprise platforms, AI agent systems, and applied ML — all on production data, for real businesses.</p>
    </section>
    <section style="padding-bottom: 4rem;">
      <div class="work-grid">
        {work.map((project) => (
          <a href={`/work/${project.id}`} class="work-card">
            <span class="work-card__sector">{project.data.sector}</span>
            <h3 class="work-card__title">{project.data.title}</h3>
            <p class="work-card__desc">{project.data.description}</p>
            <div class="tech-tags">
              {project.data.tech.map((t: string) => <span class="tech-tag">{t}</span>)}
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
