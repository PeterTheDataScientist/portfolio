---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const work = (await getCollection('work')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);
---

<BaseLayout title="Work" description="Capability areas spanning enterprise AI, production platforms, live ERP integration, and applied machine learning.">
  <section class="band band--hero">
    <div class="container">
      <p class="hero__eyebrow">Work</p>
      <h1 class="hero__title">Built for <em>real problems.</em></h1>
      <p class="hero__subtitle">Capability areas across applied machine learning, AI engineering, analytics, and the production platforms that put data science to work, all on real data for real businesses.</p>
    </div>
  </section>
  <section class="band band--tight">
    <div class="container">
      <div class="work-grid">
        {work.map((project) => (
          <a href={`/work/${project.id}`} class="work-card" data-reveal>
            <span class="work-card__sector">{project.data.sector}</span>
            <h3 class="work-card__title">{project.data.title}</h3>
            <p class="work-card__desc">{project.data.description}</p>
            <div class="tech-tags">
              {project.data.tech.map((t: string) => <span class="tech-tag">{t}</span>)}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
