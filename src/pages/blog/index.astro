---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Writing" description="Thoughts on enterprise AI, data engineering, and building in Africa.">
  <div class="container">
    <section class="hero">
      <p class="hero__eyebrow">Writing</p>
      <h1 class="hero__title">Thinking out <em>loud.</em></h1>
    </section>
    <section style="padding-bottom: 4rem;">
      <div class="blog-list">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="blog-item">
            <span class="blog-item__title">{post.data.title}</span>
            <span class="blog-item__date">{post.data.date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
