---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Peter Tinashe Mundowa about enterprise AI, data infrastructure, and collaborations.">
  <div class="container">
    <section class="hero">
      <p class="hero__eyebrow">Contact</p>
      <h1 class="hero__title">Got a problem worth <em>solving?</em></h1>
      <p class="hero__subtitle">Open to conversations about enterprise AI, data infrastructure, and collaborations that move the African tech ecosystem forward.</p>
    </section>
    <section style="padding-bottom: 4rem;">
      <div class="contact-links">
        <button class="contact-link email-reveal" id="email-reveal" type="button" aria-label="Reveal email address">
          <span>Email</span>
          <span class="contact-link__label" id="email-text">Click to reveal email</span>
        </button>
        <a href="/cv.pdf" download class="contact-link">
          <span>Download CV</span>
          <span class="contact-link__label">PDF</span>
        </a>
        <a href="https://www.linkedin.com/in/peter-tinashe-mundowa-758a2b239" target="_blank" rel="noopener" class="contact-link">
          <span>LinkedIn</span>
          <span class="contact-link__label">Peter Tinashe Mundowa</span>
        </a>
        <a href="https://github.com/PeterTheDataScientist" target="_blank" rel="noopener" class="contact-link">
          <span>GitHub</span>
          <span class="contact-link__label">PeterTheDataScientist</span>
        </a>
        <a href="https://zindi.africa/users/PeterTheAnalyst" target="_blank" rel="noopener" class="contact-link">
          <span>Zindi</span>
          <span class="contact-link__label">Ambassador, Zimbabwe</span>
        </a>
        <a href="https://rightforeducation.org/author/peter-tinashe-mundowa/" target="_blank" rel="noopener" class="contact-link">
          <span>Right for Education</span>
          <span class="contact-link__label">Author on African tech and education</span>
        </a>
      </div>
    </section>
  </div>

  <script is:inline>
    (function () {
      var btn = document.getElementById('email-reveal');
      var label = document.getElementById('email-text');
      if (!btn || !label) return;
      var revealed = false;
      btn.addEventListener('click', function () {
        var addr = ['petermundowa25', 'gmail.com'].join('@');
        if (!revealed) {
          label.textContent = addr;
          btn.setAttribute('aria-label', 'Email ' + addr);
          revealed = true;
        } else {
          window.location.href = 'mailto:' + addr;
        }
      });
    })();
  </script>
</BaseLayout>
