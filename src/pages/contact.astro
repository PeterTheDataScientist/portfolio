---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Peter Tinashe Mundowa — enterprise AI, data infrastructure, and collaborations.">
  <div class="container">
    <section class="hero">
      <p class="hero__eyebrow">Contact</p>
      <h1 class="hero__title">Got a problem worth <em>solving?</em></h1>
      <p class="hero__subtitle">Open to conversations about enterprise AI, data infrastructure, and collaborations that move the African tech ecosystem forward.</p>
    </section>
    <section style="padding-bottom: 4rem;">
      <div class="contact-links">
        <a href="https://www.linkedin.com/in/petertinashemundowa" target="_blank" rel="noopener" class="contact-link">
          <span>LinkedIn</span>
          <span class="contact-link__label">Peter Tinashe Mundowa</span>
        </a>
        <a href="https://github.com/PeterTheDataScientist" target="_blank" rel="noopener" class="contact-link">
          <span>GitHub</span>
          <span class="contact-link__label">PeterTheDataScientist</span>
        </a>
        <a href="https://zindi.africa/users/PeterTheAnalyst" target="_blank" rel="noopener" class="contact-link">
          <span>Zindi</span>
          <span class="contact-link__label">Ambassador — Zimbabwe</span>
        </a>
        <a href="https://rightforeducation.org/author/peter-tinashe-mundowa/" target="_blank" rel="noopener" class="contact-link">
          <span>Right for Education</span>
          <span class="contact-link__label">Author — African tech & education</span>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
